# Fichier de configuration d'environnement (.env)
# Renommez ce fichier en `.env` et ajoutez vos clés API.

# Clé API pour Gemini (obligatoire si vous choisissez le modèle Gemini)
GOOGLE_API_KEY="votre_cle_api_google_ici"

# URL pour Ollama (obligatoire si vous choisissez le modèle Ollama en local)
# Par défaut : http://localhost:11434
OLLAMA_BASE_URL="http://localhost:11434"
